    function  fmiExitModelInitializationMode
    input fmiModel fmi;
    output Real dummy=1.0;
    external"C" SMS_model38285405448540750123_fmiExitModelInitializationMode2(fmi)
    annotation (Include="
#ifndef SMS_model38285405448540750123_fmiExitModelInitializationMode_C
#define SMS_model38285405448540750123_fmiExitModelInitializationMode_C 1
#include <stdlib.h>
#include \"FMI/fmi2Import.h\"
void SMS_model38285405448540750123_fmiExitModelInitializationMode2(void*m) {
  struct dy_fmi2Extended*a=m;
  fmi2Status status=fmi2Fatal;
  if (a) {
    if(a->currentMode==dyfmi2InitializationMode){
      status=a->dyFmiExitInitializationMode(a->m);
      a->dyTriggered=0;
      a->dyLastTime=a->dyTime;
      a->currentMode = dyfmi2EventMode;
      a->cpDer = 1;
      a->cpOut = 1;
    }else{ status = fmi2OK;} 
  }
  if (status!=fmi2OK && status!=fmi2Warning) ModelicaError(\"fmiExitModelInitialization failed!\");
  return;
}
#endif", Library="SMS_model", LibraryDirectory="modelica://SMS_model_fmu/Resources/Library/FMU/SMS_model/binaries");
      annotation (
        __Dymola_doNotLinkSharedObject=true,
