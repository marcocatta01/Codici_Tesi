#define SMS_model38285405448540750123_fmiCheckIfDiscreteValueSet_C 1
#include \"FMI/fmi2Import.h\"
double SMS_model38285405448540750123_fmiCheckIfDiscreteValueSet2(void*m) {
  struct dy_fmi2Extended*a=m;
  if (a) {
    return a->discreteInputChanged;
  }
  ModelicaError(\"fmiCheckIfDiscreteValueSet2 failed!\");
