    record body_rec
      constant Boolean animation = true "= true, if animation shall be enabled (show shape between frame_a and frame_b and optionally a sphere at the center of mass)";
      constant Boolean animateSphere = false "= true, if mass shall be animated as sphere provided animation=true";
      constant Modelica.Units.SI.Position r[3]  = {0, 0, 0} "Vector from frame_a to frame_b resolved in frame_a";
      constant Modelica.Units.SI.Position r_CM[3]  = {0, 0, 0} "Vector from frame_a to center of mass, resolved in frame_a";
      constant Modelica.Units.SI.Mass m = 150.0 "Mass of rigid body";
      constant Modelica.Units.SI.Inertia I_11(min = 0.0) = 15.0 "Element (1,1) of inertia tensor";
      constant Modelica.Units.SI.Inertia I_22(min = 0.0) = 21.8 "Element (2,2) of inertia tensor";
      constant Modelica.Units.SI.Inertia I_33(min = 0.0) = 18.88 "Element (3,3) of inertia tensor";
      constant Modelica.Units.SI.Inertia I_21(min = -1E+60) = 0.0 "Element (2,1) of inertia tensor";
      constant Modelica.Units.SI.Inertia I_31(min = -1E+60) = 0.0 "Element (3,1) of inertia tensor";
      constant Modelica.Units.SI.Inertia I_32(min = -1E+60) = 0.0 "Element (3,2) of inertia tensor";
      Modelica.Units.SI.Position r_0[3] "Position vector from origin of world frame to origin of frame_a";
      Real '_r_0[1]_der'(unit = "m/s") "der(Position vector from origin of world frame to origin of frame_a)";
      Real '_r_0[2]_der'(unit = "m/s") "der(Position vector from origin of world frame to origin of frame_a)";
      Real '_r_0[3]_der'(unit = "m/s") "der(Position vector from origin of world frame to origin of frame_a)";
      Modelica.Units.SI.Velocity v_0[3] "Absolute velocity of frame_a, resolved in world frame (= der(r_0))";
      Real '_v_0[1]_der'(unit = "m/s2") "der(Absolute velocity of frame_a, resolved in world frame (= der(r_0)))";
      Real '_v_0[2]_der'(unit = "m/s2") "der(Absolute velocity of frame_a, resolved in world frame (= der(r_0)))";
      Real '_v_0[3]_der'(unit = "m/s2") "der(Absolute velocity of frame_a, resolved in world frame (= der(r_0)))";
      Modelica.Units.SI.Acceleration a_0[3] "Absolute acceleration of frame_a resolved in world frame (= der(v_0))";
      constant Boolean angles_fixed = true "= true, if angles_start are used as initial values, else as guess values";
      Modelica.Units.SI.Angle angles_start[3] "Initial values of angles to rotate world frame around 'sequence_start' axes into frame_a";
      constant Integer sequence_start[3]( min = 1, max = 3) = {3, 1, 3} "Sequence of rotations to rotate world frame into frame_a at initial time";
      constant Boolean w_0_fixed = true "= true, if w_0_start are used as initial values, else as guess values";
      Modelica.Units.SI.AngularVelocity w_0_start[3] "Initial or guess values of angular velocity of frame_a resolved in world frame";
      constant Boolean z_0_fixed = false "= true, if z_0_start are used as initial values, else as guess values";
      constant Modelica.Units.SI.AngularAcceleration z_0_start[3]  = {0.0, 0.0, 0.0} "Initial values of angular acceleration z_0 = der(w_0)";
      constant Modelica.Units.SI.Position r_shape[3]  = {-1.5, 0.0, 0.0} "Vector from frame_a to shape origin, resolved in frame_a";
      constant Real lengthDirection[3]  = {1.0, 0.0, 0.0} "Vector in length direction of shape, resolved in frame_a";
      constant Real widthDirection[3]  = {0.0, 1.0, 0.0} "Vector in width direction of shape, resolved in frame_a";
      constant Modelica.Units.SI.Length length = 3.0 "Length of shape";
      constant Modelica.Units.SI.Distance width = 3.0 "Width of shape";
      constant Modelica.Units.SI.Distance height = 3.0 "Height of shape";
      constant Modelica.Mechanics.MultiBody.Types.ShapeExtra extra = 0.0 "Additional parameter depending on shapeType (see docu of Visualizers.Advanced.Shape)";
      constant Integer color[3]( min = 0, max = 255) = {0, 128, 255} "Color of shape";
      constant Modelica.Units.SI.Diameter sphereDiameter = 6.0 "Diameter of sphere";
      constant Integer sphereColor[3]( min = 0, max = 255) = {0, 128, 255} "Color of sphere of mass";
      constant Modelica.Mechanics.MultiBody.Types.SpecularCoefficient specularCoefficient = 0.7 "Reflection of ambient light (= 0: light is completely absorbed)";
      constant Boolean enforceStates = false "= true, if absolute variables of body object shall be used as states (StateSelect.always)";
      constant Boolean useQuaternions = true "= true, if quaternions shall be used as potential states otherwise use 3 angles as potential states";
      constant Integer sequence_angleStates[3]( min = 1, max = 3) = {1, 2, 3} "Sequence of rotations to rotate world frame into frame_a around the 3 angles used as potential states";
      Modelica.Units.SI.Acceleration g[3];
