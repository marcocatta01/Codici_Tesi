    Modelica.Units.SI.Velocity v_0[3](fixed=false) "Absolute velocity of frame_a, resolved in world frame (= der(r_0))";
    Modelica.Units.SI.Acceleration a_0[3] "Absolute acceleration of frame_a resolved in world frame (= der(v_0))";
    constant Boolean isControlled = true "=true, if the AOCS system of the spacecraft is active";
    constant Modelica.Mechanics.MultiBody.Types.ResolveInFrameB ControlActionResolve = Modelica.Mechanics.MultiBody.Types.ResolveInFrameB.frame_b "Frame in which the control force and torque acting on the spacecraft is resolved (1: world frame, 2: frame_b - SC center of mass, 3: frame_resolve - specify a different ref. frame)";
    constant Boolean useManipulator = true "=true, enables an additional frame connector, to be used as the base of a manipulator mounted onboard";
    Modelica.Units.SI.Position ManipFrame_pos[3] "Manipulator attach frame position resolved in the body fixed frame";
    Modelica.Units.NonSI.Angle_deg ManipFrame_rot[3] "Euler angles of the manipulator attach frame w.r.t. the body fixed frame";
    constant Boolean useCamera = true "=true, enables an additional frame connector, to be used as the reference frame of a body-mounted camera";
    Modelica.Units.SI.Position CamFrame_pos[3] "Camera frame position resolved in the body fixed frame";
    Modelica.Units.NonSI.Angle_deg CamFrame_rot[3] "Euler angles of the camera frame w.r.t. the body fixed frame";
    constant Boolean useGraspingPoint = false "=true, enables an additional frame connector, to be used as the reference frame of the grasping/docking point";
    parameter Modelica.Units.SI.Position GPFrame_pos[3] = {0, 0, 0} "Grasping Point frame position resolved in the body fixed frame";
    constant Modelica.Units.NonSI.Angle_deg GPFrame_rot[3]  = {0, 0, 0} "Euler angles of the grasping point frame w.r.t. the body fixed frame";
    constant Boolean animation = true "= true, if animation shall be enabled (show shape between frame_a and frame_b and optionally a sphere at the center of mass)";
    constant Boolean animateCMFrame = true "= true, if the CM frame shall be animated, provided animation=true";
    constant Boolean animateCameraFrame = false "= true, if the camera frame shall be animated, provided animation=true";
    constant Boolean animateGPFrame = false "= true, if the grasping point frame shall be animated, provided animation=true";
    constant Modelica.Units.SI.Mass mass = 150.0 "Mass of the spacecraft";
    constant Modelica.Units.SI.Inertia I_11(min = 0.0) = 15 "Element (1,1) of inertia tensor";
    constant Modelica.Units.SI.Inertia I_22(min = 0.0) = 21.8 "Element (2,2) of inertia tensor";
    constant Modelica.Units.SI.Inertia I_33(min = 0.0) = 18.88 "Element (3,3) of inertia tensor";
    constant Modelica.Units.SI.Inertia I_21(min = -1E+60) = 0 "Element (2,1) of inertia tensor";
    constant Modelica.Units.SI.Inertia I_31(min = -1E+60) = 0 "Element (3,1) of inertia tensor";
    constant Modelica.Units.SI.Inertia I_32(min = -1E+60) = 0 "Element (3,2) of inertia tensor";
    constant Boolean angles_fixed = true "= true, if angles_start are used as initial values, else as guess values";
    Modelica.Units.SI.Angle angles_start[3] "Initial values of angles to rotate world frame around 'sequence_start' axes into frame_a";
    constant Integer sequence_start[3]( min = 1, max = 3) = {3, 1, 3} "Sequence of rotations to rotate world frame into frame_a at initial time";
    constant Boolean w_0_fixed = true "= true, if w_0_start are used as initial values, else as guess values";
    Modelica.Units.SI.AngularVelocity w_0_start[3](displayUnit = "deg/s") "Initial or guess values of angular velocity of frame_a resolved in world frame";
    constant Boolean z_0_fixed = false "= true, if z_0_start are used as initial values, else as guess values";
    constant Modelica.Units.SI.AngularAcceleration z_0_start[3]  = {0, 0, 0} "Initial values of angular acceleration z_0 = der(w_0)";
    constant Modelica.Units.SI.Position r_shape[3]  = {-1.5, 0.0, 0.0} "Vector from CM_frame to shape origin, resolved in CM_frame";
    constant Real lengthDirection[3]  = {1.0, 0.0, 0.0} "Vector in length direction of shape, resolved in CM_frame";
    constant Real widthDirection[3]  = {0, 1, 0} "Vector in width direction of shape, resolved in CM_frame";
    constant Modelica.Units.SI.Length length = 3 "Length of shape";
    constant Modelica.Units.SI.Distance width = 3 "Width of shape";
    constant Modelica.Units.SI.Distance height = 3 "Height of shape";
    constant Integer color[3]( min = 0, max = 255) = {0, 128, 255} "Color of shape";
    constant Modelica.Units.SI.Length CMframe_axisLength = 4.5 "Length of the axes of the CM frame";
    constant Integer CMframe_axisColor[3]( min = 0, max = 255) = {255, 0, 255} "Color of CM frame axes";
    constant Modelica.Mechanics.MultiBody.Types.SpecularCoefficient specularCoefficient = 0.7 "Reflection of ambient light (= 0: light is completely absorbed)";
    constant Boolean enforceStates = false "= true, if absolute variables of body object shall be used as states (StateSelect.always)";
    constant Boolean useQuaternions = true "= true, if quaternions shall be used as potential states otherwise use 3 angles as potential states";
    constant Integer sequence_angleStates[3]( min = 1, max = 3) = {1, 2, 3} "Sequence of rotations to rotate world frame into frame_a around the 3 angles used as potential states";
