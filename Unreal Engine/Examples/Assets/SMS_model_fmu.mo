  static const fmi2ValueReference vr[6] = {335544320, 335544321, 335544322, 335544323, 335544324, 335544325, 335544326, 335544327, 335544328, 335544329, 335544330, 335544331, 335544332, 335544333, 335544334, 335544335, 335544336, 335544337};
  if (a) {
